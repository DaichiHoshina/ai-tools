#!/usr/bin/env bash
set -euo pipefail

# codexをiTerm2の新タブで起動する
# Claude Code内から ! codex-open "レビューして" で使用
# TTYが必要なcodex対話モードをClaude Codeから起動するためのラッパー

PROMPT="${*:-直近の変更をレビューして}"
CWD="$(pwd)"

# AppleScript内で安全に展開するためエスケープ
ESCAPED_CWD="${CWD//\\/\\\\}"
ESCAPED_CWD="${ESCAPED_CWD//\"/\\\"}"
ESCAPED_PROMPT="${PROMPT//\\/\\\\}"
ESCAPED_PROMPT="${ESCAPED_PROMPT//\"/\\\"}"

osascript -e "
tell application \"iTerm2\"
    tell current window
        create tab with default profile
        tell current session
            write text \"cd \\\"${ESCAPED_CWD}\\\" && codex \\\"${ESCAPED_PROMPT}\\\"\"
        end tell
    end tell
end tell
"
