{
  "model": "claude-fable-5",
  "fallbackModel": ["claude-opus-4-7", "claude-sonnet-4-6", "claude-haiku-4-5"],
  "alwaysThinkingEnabled": false,
  "env": {
    "CLAUDE_CODE_AUTO_CONNECT_IDE": "false",
    "CLAUDE_CODE_IDE_SKIP_AUTO_INSTALL": "true",
    "CLAUDE_CODE_IDE_SKIP_VALID_CHECK": "true",
    "CLAUDE_CODE_ENABLE_TELEMETRY": "false",
    "CLAUDE_CODE_DISABLE_NONESSENTIAL_TRAFFIC": "true",
    "DISABLE_ERROR_REPORTING": "true",
    "DISABLE_TELEMETRY": "true",
    "DISABLE_AUTOUPDATER": "true",
    "DISABLE_MICROCOMPACT": "false",
    "CLAUDE_CODE_NO_FLICKER": "1",
    "CLAUDE_CODE_DISABLE_THINKING": "1",
    "CLAUDE_CODE_MAX_OUTPUT_TOKENS": "32000",
    "ENABLE_PROMPT_CACHING_1H": "true",
    "CLAUDE_CODE_ENABLE_AWAY_SUMMARY": "true"
  },
  "sandbox": {
    "network": {
      "deniedDomains": [
        "169.254.169.254",
        "metadata.google.internal",
        "100.100.100.200"
      ]
    }
  },
  "worktree": {
    "baseRef": "fresh"
  },
  "claudeMdExcludes": [
    "**/ghq/github.com/*/*/CLAUDE.md",
    "**/ghq/github.com/*/*/CLAUDE.local.md",
    "**/ghq/github.com/*/*/.claude/CLAUDE.md",
    "**/ghq/github.com/*/*/.claude/rules/**"
  ],
  "permissions": {
    "allow": [
      "Bash(git *)",
      "Bash(npm *)",
      "Bash(npx *)",
      "Bash(go *)",
      "Bash(make *)",
      "Bash(gh *)",
      "Bash(cargo *)",
      "Bash(uv *)",
      "Bash(docker *)",
      "Bash(*--help*)",
      "Bash(*--version*)"
    ],
    "deny": [
      "NotebookEdit",

      "Bash(sudo *)",
      "Bash(su *)",
      "Bash(chmod 777 *)",
      "Bash(curl*|*sh)",
      "Bash(wget*|*sh)",
      "Bash(curl*|*bash)",
      "Bash(wget*|*bash)",
      "Bash(sh -c*curl*)",
      "Bash(bash -c*curl*)",
      "Bash(*> /etc/*)",
      "Bash(*>> /etc/*)",

      "Bash(rm -rf /)",
      "Bash(rm -rf /*)",
      "Bash(rm -rf ~)",
      "Bash(rm -rf ~/*)",
      "Bash(rm -rf $HOME)",
      "Bash(rm -rf $HOME/*)",
      "Bash(rm -r /)",
      "Bash(rm -r ~)",
      "Bash(rm -fr *)",
      "Bash(rm -rf .)",
      "Bash(rm -rf ./*)",
      "Bash(rmdir /)",

      "Bash(git push*--force*main)",
      "Bash(git push*--force*master)",
      "Bash(git push*-f*main)",
      "Bash(git push*-f*master)",
      "Bash(git reset --hard)",
      "Bash(git reset --hard *)",
      "Bash(git clean -fd)",
      "Bash(git clean -fdx)",
      "Bash(git checkout .)",
      "Bash(git restore .)",
      "Bash(git stash drop)",
      "Bash(git branch -D main)",
      "Bash(git branch -D master)",

      "Bash(mkfs*)",
      "Bash(dd if=*of=/dev/*)",
      "Bash(history -c)",
      "Bash(shred *)",

      "Bash(env)",
      "Bash(printenv)",
      "Bash(printenv *)",
      "Bash(set)",
      "Bash(export -p)",
      "Bash(cat /proc/*/environ)",
      "Bash(*cat*/proc/*)",
      "Bash(git config --list*)",
      "Bash(git config -l*)",
      "Bash(npm config list*)",
      "Bash(curl*169.254*)",
      "Bash(wget*169.254*)",
      "Bash(curl*metadata.google*)",
      "Bash(wget*metadata.google*)",
      "Bash(curl*100.100.100.200*)",
      "Bash(wget*100.100.100.200*)",

      "Read(.env)",
      "Read(.env.*)",
      "Read(**/.env)",
      "Read(**/.env.*)",
      "Edit(.env)",
      "Edit(.env.*)",
      "Edit(**/.env)",
      "Edit(**/.env.*)",
      "Write(.env)",
      "Write(.env.*)",
      "Write(**/.env)",
      "Write(**/.env.*)",
      "Read(**/*.pem)",
      "Edit(**/*.pem)",
      "Write(**/*.pem)",
      "Read(**/*secret*)",
      "Edit(**/*secret*)",
      "Write(**/*secret*)",
      "Read(**/*credential*)",
      "Edit(**/*credential*)",
      "Write(**/*credential*)",
      "Read(**/*password*)",
      "Edit(**/*password*)",
      "Write(**/*password*)",
      "Read(~/.ssh/**)",
      "Read(~/.aws/**)",
      "Read(~/.config/gh/**)",
      "Read(~/.gnupg/**)",
      "Read(~/.netrc)",
      "Read(~/.npmrc)",
      "Read(~/.kube/**)",
      "Read(~/.gcloud/**)",
      "Read(~/.azure/**)",
      "Read(~/.git-credentials)",
      "Read(~/.docker/config.json)",
      "Read(**/*.token)",
      "Read(**/*_token.json)",
      "Read(**/*_token.yaml)",
      "Edit(**/*.token)",
      "Write(**/*.token)"
    ],
    "defaultMode": "auto"
  },
  "hooks": {
    "Setup": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/setup.sh"
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/session-start.sh"
          }
        ]
      },
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/serena-hook.sh activate"
          }
        ]
      },
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/scripts/memory-dangling-check.sh",
            "async": true
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/user-prompt-submit.sh"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/pre-tool-use.sh"
          }
        ]
      },
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/serena-hook.sh remind"
          }
        ]
      },
      {
        "matcher": "mcp__serena__*",
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/serena-hook.sh auto-approve"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/post-tool-use.sh",
            "async": true
          }
        ]
      }
    ],
    "PreCompact": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/pre-compact.sh"
          }
        ]
      }
    ],
    "SubagentStart": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/subagent-start.sh"
          }
        ]
      }
    ],
    "SubagentStop": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/subagent-stop.sh"
          }
        ]
      }
    ],
    "SessionEnd": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/session-end.sh",
            "async": true
          }
        ]
      }
    ],
    "TeammateIdle": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/teammate-idle.sh",
            "async": true
          }
        ]
      }
    ],
    "TaskCompleted": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/task-completed.sh",
            "async": true
          }
        ]
      }
    ],
    "PostCompact": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/post-compact-reload.sh"
          }
        ]
      }
    ],
    "Stop": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/stop.sh",
            "async": true
          },
          {
            "type": "command",
            "command": "~/.claude/hooks/stop-verify.sh"
          }
        ]
      },
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/serena-hook.sh cleanup",
            "async": true
          }
        ]
      }
    ],
    "StopFailure": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/stop-failure.sh",
            "async": true
          }
        ]
      }
    ],
    "PostToolUseFailure": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/post-tool-use-failure.sh",
            "async": true
          }
        ]
      }
    ],
    "PermissionDenied": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/permission-denied.sh",
            "async": true
          }
        ]
      }
    ],
    "WorktreeRemove": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/worktree-remove.sh",
            "async": true
          }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "~/.claude/statusline.js",
    "refreshInterval": 10
  },
  "enabledPlugins": {
    "gopls-lsp@claude-plugins-official": false,
    "typescript-lsp@claude-plugins-official": false,
    "python-lsp@claude-plugins-official": false,
    "rust-analyzer-lsp@claude-plugins-official": false,
    "frontend-design@claude-plugins-official": true,
    "code-review@claude-plugins-official": true,
    "commit-commands@claude-plugins-official": true,
    "claude-md-management@claude-plugins-official": true,
    "code-simplifier@claude-plugins-official": true,
    "security-guidance@claude-plugins-official": true,
    "pr-review-toolkit@claude-plugins-official": false,
    "pyright-lsp@claude-plugins-official": false
  },
  "skillOverrides": {
    "aliases": "user-invocable-only",
    "api-design": "name-only",
    "architecture-diagram": "name-only",
    "audit": "name-only",
    "backend-dev": "name-only",
    "brainstorm": "name-only",
    "claude-api": "name-only",
    "clean-architecture-ddd": "name-only",
    "cleanup-enforcement": "name-only",
    "container-ops": "name-only",
    "data-analysis": "name-only",
    "design-doc": "name-only",
    "docs": "name-only",
    "fewer-permission-prompts": "user-invocable-only",
    "grpc-protobuf": "off",
    "incident-response": "name-only",
    "init": "user-invocable-only",
    "keybindings-help": "off",
    "lint-test": "name-only",
    "loop": "user-invocable-only",
    "mcp-setup-guide": "name-only",
    "microservices-monorepo": "name-only",
    "post-comment": "name-only",
    "prd": "name-only",
    "protection-mode": "user-invocable-only",
    "react-best-practices": "name-only",
    "refactor": "name-only",
    "schedule": "user-invocable-only",
    "serena-refresh": "user-invocable-only",
    "session-mode": "name-only",
    "skills-manage": "name-only",
    "slack-rich-copy": "name-only",
    "techdebt": "name-only",
    "terraform": "off",
    "test": "name-only",
    "ui-skills": "name-only",
    "uiux-review": "name-only",
    "verify-once": "name-only",
    "_archive:config-update": "off",
    "_archive:pr-comments": "off"
  },
  "outputStyle": "ai-tools-format",
  "language": "japanese",
  "spinnerVerbs": {
    "mode": "append",
    "verbs": [
      "考え中",
      "分析中",
      "構築中",
      "熟考中"
    ]
  },
  "effortLevel": "medium",
  "autoUpdatesChannel": "stable",
  "showThinkingSummaries": false,
  "verbose": true,
  "preferredNotifChannel": "none",
  "showTurnDuration": true,
  "skipAutoPermissionPrompt": true,
  "autocompact": true,
  "instructions": [
    "日本語で回答すること",
    "Guard関手: Safe射(読み取り)→即実行、Boundary射(編集)→確認必要、Forbidden射(破壊)→拒否",
    "any型禁止、as控える",
    "実装完了後は必ずverify-app実行",
    "2回同じアプローチで失敗したら/clearして再整理"
  ],
  "skipDangerousModePermissionPrompt": true,
  "extraKnownMarketplaces": {
    "genshijin": {
      "source": {
        "source": "github",
        "repo": "InterfaceX-co-jp/genshijin"
      }
    }
  },
  "awaySummaryEnabled": false
}
