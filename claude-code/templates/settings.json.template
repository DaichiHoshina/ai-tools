{
  "env": {
    "CLAUDE_CODE_AUTO_CONNECT_IDE": "false",
    "CLAUDE_CODE_IDE_SKIP_AUTO_INSTALL": "true",
    "CLAUDE_CODE_IDE_SKIP_VALID_CHECK": "true",
    "CLAUDE_CODE_ENABLE_TELEMETRY": "false",
    "CLAUDE_CODE_DISABLE_NONESSENTIAL_TRAFFIC": "true",
    "DISABLE_ERROR_REPORTING": "true",
    "DISABLE_TELEMETRY": "true",
    "DISABLE_AUTOUPDATER": "true",
    "DISABLE_MICROCOMPACT": "false",
    "CLAUDE_CODE_NO_FLICKER": "1",
    "MAX_THINKING_TOKENS": "20000",
    "CLAUDE_CODE_MAX_OUTPUT_TOKENS": "32000",
    "ENABLE_PROMPT_CACHING_1H": "true",
    "CLAUDE_CODE_ENABLE_AWAY_SUMMARY": "true"
  },
  "permissions": {
    "allow": [
      "Bash(git *)",
      "Bash(npm *)",
      "Bash(npx *)",
      "Bash(go *)",
      "Bash(make *)",
      "Bash(gh *)",
      "Bash(cargo *)",
      "Bash(uv *)",
      "Bash(docker *)",
      "Bash(*--help*)",
      "Bash(*--version*)"
    ],
    "deny": [
      "NotebookEdit",

      "Bash(sudo *)",
      "Bash(su *)",
      "Bash(chmod 777 *)",
      "Bash(curl*|*sh)",
      "Bash(wget*|*sh)",
      "Bash(curl*|*bash)",
      "Bash(wget*|*bash)",
      "Bash(sh -c*curl*)",
      "Bash(bash -c*curl*)",
      "Bash(*> /etc/*)",
      "Bash(*>> /etc/*)",

      "Bash(rm -rf /)",
      "Bash(rm -rf /*)",
      "Bash(rm -rf ~)",
      "Bash(rm -rf ~/*)",
      "Bash(rm -rf $HOME)",
      "Bash(rm -rf $HOME/*)",
      "Bash(rm -r /)",
      "Bash(rm -r ~)",
      "Bash(rm -fr *)",
      "Bash(rm -rf .)",
      "Bash(rm -rf ./*)",
      "Bash(rmdir /)",

      "Bash(git push*--force*main)",
      "Bash(git push*--force*master)",
      "Bash(git push*-f*main)",
      "Bash(git push*-f*master)",
      "Bash(git reset --hard)",
      "Bash(git reset --hard *)",
      "Bash(git clean -fd)",
      "Bash(git clean -fdx)",
      "Bash(git checkout .)",
      "Bash(git restore .)",
      "Bash(git stash drop)",
      "Bash(git branch -D main)",
      "Bash(git branch -D master)",

      "Bash(mkfs*)",
      "Bash(dd if=*of=/dev/*)",
      "Bash(history -c)",
      "Bash(shred *)",

      "Bash(env)",
      "Bash(printenv)",
      "Bash(printenv *)",
      "Bash(set)",
      "Bash(export -p)",
      "Bash(cat /proc/*/environ)",
      "Bash(*cat*/proc/*)",
      "Bash(git config --list*)",
      "Bash(git config -l*)",
      "Bash(npm config list*)",
      "Bash(curl*169.254*)",
      "Bash(wget*169.254*)",
      "Bash(curl*metadata.google*)",

      "Read(.env)",
      "Read(.env.*)",
      "Read(**/.env)",
      "Read(**/.env.*)",
      "Edit(.env)",
      "Edit(.env.*)",
      "Edit(**/.env)",
      "Edit(**/.env.*)",
      "Write(.env)",
      "Write(.env.*)",
      "Write(**/.env)",
      "Write(**/.env.*)",
      "Read(**/*.pem)",
      "Edit(**/*.pem)",
      "Write(**/*.pem)",
      "Read(**/*secret*)",
      "Edit(**/*secret*)",
      "Write(**/*secret*)",
      "Read(**/*credential*)",
      "Edit(**/*credential*)",
      "Write(**/*credential*)",
      "Read(**/*password*)",
      "Edit(**/*password*)",
      "Write(**/*password*)",
      "Read(~/.ssh/**)",
      "Read(~/.aws/**)",
      "Read(~/.config/gh/**)",
      "Read(~/.gnupg/**)",
      "Read(~/.netrc)",
      "Read(~/.npmrc)",
      "Read(~/.kube/**)",
      "Read(~/.gcloud/**)",
      "Read(~/.azure/**)",
      "Read(~/.git-credentials)",
      "Read(~/.docker/config.json)",
      "Read(**/*token*)",
      "Edit(**/*token*)",
      "Write(**/*token*)"
    ]
  },
  "hooks": {
    "Setup": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/setup.sh"
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/session-start.sh"
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/user-prompt-submit.sh"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/pre-tool-use.sh"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/post-tool-use.sh",
            "async": true
          }
        ]
      }
    ],
    "PreCompact": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/pre-compact.sh"
          }
        ]
      }
    ],
    "SubagentStart": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/subagent-start.sh"
          }
        ]
      }
    ],
    "SubagentStop": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/subagent-stop.sh"
          }
        ]
      }
    ],
    "SessionEnd": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/session-end.sh",
            "async": true
          }
        ]
      }
    ],
    "TeammateIdle": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/teammate-idle.sh",
            "async": true
          }
        ]
      }
    ],
    "TaskCompleted": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/task-completed.sh",
            "async": true
          }
        ]
      }
    ],
    "PostCompact": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/post-compact-reload.sh"
          }
        ]
      }
    ],
    "Stop": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/stop.sh",
            "async": true
          }
        ]
      }
    ],
    "StopFailure": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/stop-failure.sh",
            "async": true
          }
        ]
      }
    ],
    "PostToolUseFailure": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/post-tool-use-failure.sh",
            "async": true
          }
        ]
      }
    ],
    "PermissionDenied": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/permission-denied.sh",
            "async": true
          }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "~/.claude/statusline.js",
    "refreshInterval": 10
  },
  "enabledPlugins": {
    "gopls-lsp@claude-plugins-official": true,
    "typescript-lsp@claude-plugins-official": true,
    "python-lsp@claude-plugins-official": true,
    "rust-analyzer-lsp@claude-plugins-official": true,
    "frontend-design@claude-plugins-official": true,
    "code-review@claude-plugins-official": true,
    "commit-commands@claude-plugins-official": true,
    "claude-md-management@claude-plugins-official": true,
    "code-simplifier@claude-plugins-official": true,
    "security-guidance@claude-plugins-official": true,
    "pr-review-toolkit@claude-plugins-official": true,
    "pyright-lsp@claude-plugins-official": true
  },
  "outputStyle": "ai-tools-format",
  "language": "japanese",
  "spinnerVerbs": {
    "mode": "append",
    "verbs": [
      "考え中",
      "分析中",
      "構築中",
      "熟考中"
    ]
  },
  "effortLevel": "high",
  "autoUpdatesChannel": "latest",
  "showThinkingSummaries": true,
  "skipDangerousModePermissionPrompt": true,
  "extraKnownMarketplaces": {
    "genshijin": {
      "source": {
        "source": "github",
        "repo": "InterfaceX-co-jp/genshijin"
      }
    }
  }
}
