{
  "_comment": "手動設定用サンプル。自動生成は install.sh を使用（templates/.mcp.json.template から envsubst で生成）",
  "mcpServers": {
    "serena": {
      "type": "stdio",
      "command": "uv",
      "args": [
        "run",
        "--directory",
        "/path/to/serena",
        "serena-mcp-server",
        "--project",
        "/path/to/ai-tools"
      ],
      "env": {},
      "_comment": "Replace /path/to/serena with your serena installation directory, and /path/to/ai-tools with the absolute path to this repository"
    }
  }
}
