#!/usr/bin/env bash
# SessionStart Hook for .codex
# セッション開始時の自動処理

set -euo pipefail

# jq前提条件チェック
if ! command -v jq &> /dev/null; then
    echo '{"error": "jq not installed. Please run: brew install jq"}' >&2
    exit 1
fi

# JSON入力を読み込む
INPUT=$(cat)

# Serena MCPが有効かチェック
if echo "$INPUT" | jq -e '.mcp_servers | has("serena")' > /dev/null 2>&1; then
  cat <<EOF
{
  "systemMessage": "✅ .codex session initialized",
  "additionalContext": "**Serena MCP active**: repo-local analysis ready

**AI運用7原則**:
1. 質問時: \`afplay ~/button.mp3\`
2. コード探索は Serena symbolic tools を優先
3. 計画時は Context7 で最新ドキュメント確認
4. 勝手な整形・lint禁止（git差分範囲のみ）
5. 完了時: \`afplay ~/notification.mp3\` + トークン表示
6. 型安全性厳守（\`any\` 禁止）

**Development Principles**:
- ✅ 安全操作: 即実行
- ⚠️ 要確認操作: git/file operations require confirmation
- 🚫 禁止操作: dangerous operations blocked
- Type safety: Avoid 'any', minimize 'as'

Run: \`mcp__serena__initial_instructions\`, \`mcp__serena__list_memories\`, \`mcp__serena__check_onboarding_performed\`"
}
EOF
else
  cat <<EOF
{
  "systemMessage": "⚠️ Serena not configured - basic mode",
  "additionalContext": "**AI運用7原則**:
1. 質問時: \`afplay ~/button.mp3\`
2. コード探索は repo の既存ツールを優先
3. 計画時は Context7 で最新ドキュメント確認
4. 勝手な整形・lint禁止
5. 完了時: \`afplay ~/notification.mp3\`
6. 型安全性厳守（\`any\` 禁止）

**Development Principles**:
- ✅ 安全操作: 即実行
- ⚠️ 要確認操作: require confirmation
- 🚫 禁止操作: blocked
- Type safety: Avoid 'any', minimize 'as'"
}
EOF
fi
