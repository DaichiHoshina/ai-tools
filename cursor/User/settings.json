{
  "editor.fontFamily": "'SF Mono', 'JetBrains Mono', 'Hiragino Sans', 'Hiragino Kaku Gothic ProN', Menlo, monospace",
  "editor.fontLigatures": true,
  "editor.fontSize": 16,
  "editor.fontWeight": "450",
  "editor.lineHeight": 1.75,
  "editor.letterSpacing": 0.4,
  "workbench.fontAliasing": "antialiased",
  "editor.tabSize": 2,
  "editor.wordWrap": "on",
  "editor.renderWhitespace": "all",
  "editor.autoClosingBrackets": "never",
  "editor.formatOnSave": true,
  "editor.formatOnPaste": true,
  "editor.defaultFormatter": "esbenp.prettier-vscode",
  "editor.largeFileOptimizations": false,
  "diffEditor.renderSideBySide": false,
  "editor.minimap.enabled": false,
  "editor.stickyScroll.enabled": true,
  "editor.bracketPairColorization.enabled": true,
  "editor.guides.bracketPairs": "active",
  "editor.renderLineHighlight": "all",
  "editor.cursorSurroundingLines": 5,
  "editor.scrollBeyondLastLine": false,
  "editor.linkedEditing": true,
  "editor.smoothScrolling": true,
  "editor.cursorBlinking": "expand",
  "editor.cursorStyle": "line",
  "editor.cursorWidth": 2,
  "editor.cursorSmoothCaretAnimation": "on",
  "breadcrumbs.enabled": true,
  "workbench.editor.highlightModifiedTabs": true,
  "workbench.list.smoothScrolling": true,
  "files.autoSave": "onFocusChange",
  "files.insertFinalNewline": true,
  "files.trimFinalNewlines": true,
  "files.trimTrailingWhitespace": true,
  "javascript.updateImportsOnFileMove.enabled": "always",
  "typescript.updateImportsOnFileMove.enabled": "always",
  "workbench.colorTheme": "Darcula",
  "workbench.startupEditor": "none",
  "workbench.secondarySideBar.defaultVisibility": false,
  "workbench.preferredDarkColorTheme": "Darcula",
  "workbench.iconTheme": "vs-seti",
  "workbench.editor.tabSizing": "shrink",
  "editor.bracketPairColorization.independentColorPoolPerLevel": true,
  "window.titleBarStyle": "custom",
  "window.autoDetectColorScheme": false,
  "workbench.colorCustomizations": {
