  "editor.semanticHighlighting.enabled": true,
  "editor.semanticTokenColorCustomizations": {
    "enabled": true,
    "rules": {
      "namespace": "#7dcfff",
      "class": {
        "foreground": "#9ece6a",
        "bold": true
      },
      "interface": {
        "foreground": "#2ac3de",
        "italic": true
      },
      "enum": "#2ac3de",
      "type": "#2ac3de",
      "typeParameter": {
        "foreground": "#bb9af7",
        "italic": true
      },
      "function": "#7aa2f7",
      "method": "#7aa2f7",
      "property": "#73daca",
      "variable": "#c0caf5",
      "variable.readonly": {
        "foreground": "#bb9af7",
        "italic": true
      },
      "parameter": {
        "foreground": "#e0af68",
        "italic": true
      },
      "enumMember": "#bb9af7",
      "*.static": {
        "italic": true
      },
      "*.deprecated": {
        "strikethrough": true,
        "foreground": "#565f89"
      }
    }
  },
  "editor.tokenColorCustomizations": {
    "textMateRules": [
      {
        "scope": [
          "keyword",
          "keyword.control",
          "storage.type",
          "storage.modifier",
          "keyword.operator.new"
        ],
        "settings": {
          "foreground": "#bb9af7",
          "fontStyle": ""
        }
      },
      {
        "scope": ["string", "string.quoted", "string.template"],
        "settings": {
          "foreground": "#9ece6a"
        }
      },
      {
        "scope": ["string.regexp"],
        "settings": {
          "foreground": "#b4f9f8"
        }
      },
      {
        "scope": ["constant.numeric", "constant.language"],
        "settings": {
          "foreground": "#ff9e64"
        }
      },
      {
        "scope": [
          "constant.language.boolean",
          "constant.language.null",
          "constant.language.undefined"
        ],
        "settings": {
          "foreground": "#ff9e64",
          "fontStyle": ""
        }
      },
      {
        "scope": ["comment", "punctuation.definition.comment"],
        "settings": {
          "foreground": "#565f89",
          "fontStyle": "italic"
        }
      },
      {
        "scope": ["comment.block.documentation", "comment.line.documentation"],
        "settings": {
          "foreground": "#565f89",
          "fontStyle": "italic"
        }
      },
      {
        "scope": [
          "entity.name.function",
          "support.function",
          "meta.function-call"
        ],
        "settings": {
          "foreground": "#7aa2f7"
        }
      },
      {
        "scope": [
          "entity.name.class",
          "entity.name.type",
          "support.class",
          "support.type"
        ],
        "settings": {
          "foreground": "#2ac3de",
          "fontStyle": "bold"
        }
      },
      {
        "scope": ["entity.name.tag"],
        "settings": {
          "foreground": "#f7768e"
        }
      },
      {
        "scope": ["entity.other.attribute-name"],
        "settings": {
          "foreground": "#bb9af7"
        }
      },
      {
        "scope": ["variable.parameter"],
        "settings": {
          "foreground": "#e0af68",
          "fontStyle": "italic"
        }
      },
      {
        "scope": ["variable.other.constant", "variable.other.enummember"],
        "settings": {
          "foreground": "#bb9af7"
        }
      },
      {
        "scope": ["variable.language.this", "variable.language.self"],
        "settings": {
          "foreground": "#f7768e",
          "fontStyle": "italic"
        }
      },
      {
        "scope": ["meta.object-literal.key", "support.type.property-name"],
        "settings": {
          "foreground": "#73daca"
        }
      },
      {
        "scope": [
          "punctuation.definition.template-expression",
          "string.template variable"
        ],
        "settings": {
          "foreground": "#7dcfff"
        }
      },
      {
        "scope": ["markup.heading"],
        "settings": {
          "foreground": "#7aa2f7",
          "fontStyle": "bold"
        }
      },
      {
        "scope": ["markup.bold"],
        "settings": {
          "fontStyle": "bold"
        }
      },
      {
        "scope": ["markup.italic"],
        "settings": {
          "fontStyle": "italic"
        }
      },
      {
        "scope": ["markup.inline.raw", "markup.fenced_code"],
        "settings": {
          "foreground": "#9ece6a"
        }
      }
    ]
  },
  "security.workspace.trust.untrustedFiles": "open",
  "accessibility.signalOptions.volume": 0,
  "claudeCode.preferredLocation": "panel",
  "markdown-preview-enhanced.previewTheme": "atom-light.css",
  "debug.console.fontSize": 14,
  "debug.console.fontFamily": "'SF Mono', 'JetBrains Mono', Menlo, monospace",
  "chat.editor.fontSize": 14,
  "chat.editor.fontFamily": "'SF Mono', 'JetBrains Mono', Menlo, monospace",
  "terminal.integrated.fontSize": 14,
  "terminal.integrated.fontFamily": "'SF Mono', 'JetBrains Mono', Menlo, monospace",
  "terminal.integrated.lineHeight": 1.35,
  "terminal.integrated.tabs.enabled": false,
  "terminal.integrated.cursorStyle": "line",
  "terminal.integrated.cursorBlinking": true,
  "git.autofetch": true,
  "makefile.configureOnOpen": true,
  "go.toolsManagement.autoUpdate": true,
  "git.openRepositoryInParentFolders": "always",
  "workbench.editor.enablePreview": false,
  "workbench.editor.closeEmptyGroups": true,
  "workbench.tree.indent": 16,
  "workbench.tree.renderIndentGuides": "always",
  "editor.tabCompletion": "on",
  "editor.suggestSelection": "first",
  "editor.acceptSuggestionOnEnter": "smart",
  "editor.hover.delay": 400,
  "editor.parameterHints.enabled": true,
  "editor.unicodeHighlight.ambiguousCharacters": false,
  "editor.unicodeHighlight.invisibleCharacters": false,
  "editor.stickyScroll.maxLineCount": 5,
  "editor.gotoLocation.multipleDefinitions": "goto",
  "editor.gotoLocation.multipleReferences": "goto",
  "explorer.compactFolders": false,
  "explorer.confirmDelete": false,
  "explorer.confirmDragAndDrop": false,
  "search.smartCase": true,
  "search.showLineNumbers": true,
  "diffEditor.wordWrap": "on",
  "git.confirmSync": false,
  "git.autorefresh": true,
  "terminal.integrated.scrollback": 10000,
  "terminal.integrated.gpuAcceleration": "on",
  "terminal.integrated.defaultLocation": "view",
  "terminal.integrated.enablePersistentSessions": true,
  "files.eol": "\n",
  "files.watcherExclude": {
    "**/.git/objects/**": true,
    "**/node_modules/**": true,
    "**/.next/**": true,
    "**/dist/**": true
  },
  "[typescript]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode"
  },
  "[typescriptreact]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode"
  },
  "[javascript]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode"
  },
  "[javascriptreact]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode"
  },
  "[json]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode"
  },
  "[jsonc]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode"
  },
  "[markdown]": {
    "editor.wordWrap": "on",
    "editor.quickSuggestions": {
      "comments": "off",
      "strings": "off",
      "other": "off"
    }
  },
  "[go]": {
    "editor.defaultFormatter": "golang.go",
    "editor.formatOnSave": true,
    "editor.codeActionsOnSave": {
      "source.organizeImports": "explicit"
    }
  },
  "[yaml]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode",
    "editor.tabSize": 2
  }
}
