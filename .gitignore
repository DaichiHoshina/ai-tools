# Serena プロジェクト固有ファイル（個人情報・機密情報を含む可能性）
.serena/

# MCP設定（環境依存のため除外、.mcp.json.exampleを参照）
.mcp.json

# Codex設定（テンプレートのみ管理、実ファイルは除外）
codex/AGENTS.md
codex/config.toml
codex/hooks/*.sh
!codex/*.example
!codex/COMMANDS.md

# Codex system skills（Codexプラグインが自動管理）
claude-code/skills/.system/

# 環境変数ファイル
.env
.env.local
.env.*.local

# Node.js
node_modules/
package-lock.json

# OS生成ファイル
.DS_Store
Thumbs.db

# エディタ設定
.vscode/
.idea/
*.swp
*.swo
*~

# ログファイル
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Python
__pycache__/
*.py[cod]
*$py.class
.pytest_cache/

# groove実行結果（ランタイム生成）
.groove/runs/*
!.groove/runs/.gitkeep

# 一時ファイル
tmp/
temp/
*.tmp

# バックアップファイル
*.backup
*.bak
