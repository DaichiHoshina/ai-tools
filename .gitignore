# Serena プロジェクト固有ファイル（個人情報・機密情報を含む可能性）
.serena/

# comprehensive-review skill の履歴（個人作業ログ、別開発者と混ざるのを防ぐ）
.claude/review-history.jsonl

# MCP設定（環境依存のため除外、.mcp.json.exampleを参照）
.mcp.json

# Codex設定（テンプレートのみ管理、実ファイルは除外）
codex/AGENTS.md
codex/config.toml
codex/hooks.json
codex/hooks/*.sh
!codex/*.example
!codex/COMMANDS.md

# Codex system skills（Codexプラグインが自動管理）
claude-code/skills/.system/

# 環境変数ファイル
.env
.env.local
.env.*.local

# Node.js
node_modules/
package-lock.json

# OS生成ファイル
.DS_Store
Thumbs.db

# エディタ設定
.vscode/
!cursor/templates/**/.vscode/
.idea/
*.swp
*.swo
*~

# ログファイル
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Python
__pycache__/
*.py[cod]
*$py.class
.pytest_cache/

# groove（定義は~/.groove/に配置、プロジェクト側はオーバーライド用）
.groove/

# 一時ファイル
tmp/
temp/
*.tmp

# バックアップファイル
*.backup
*.bak

# Claude Code agent isolation worktree dir (一時)
.claude/worktrees/

# Claude Code session 一時生成物 / sync 先 (個人作業領域、canonical は claude-code/ 配下)
.claude/commands/
.claude/plans/
# マシン固有 permission (個人パス入り)。共有したい permission は .claude/settings.json へ昇格する
.claude/settings.local.json
.claire/
.playwright-mcp/
/memory/
pr-drafts/
